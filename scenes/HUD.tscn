[gd_scene format=3 uid="uid://hud_tscn"]

[ext_resource type="Script" path="res://scripts/HUD.gd" id="1_hud"]

[sub_resource type="StyleBoxFlat" id="Style_panel"]
bg_color = Color(0, 0, 0, 0.65)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_left = 8
corner_radius_bottom_right = 8
content_margin_left = 12.0
content_margin_right = 12.0
content_margin_top = 8.0
content_margin_bottom = 8.0

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1_hud")

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 0
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 0.0
anchor_bottom = 0.0
offset_left = 12.0
offset_top = 12.0
offset_right = 220.0
offset_bottom = 180.0
theme_override_styles/panel = SubResource("Style_panel")

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="TitleLabel" type="Label" parent="Panel/VBox"]
text = "— TASKS —"
theme_override_colors/font_color = Color(1, 0.9, 0.3, 1)

[node name="Task1Label" type="Label" parent="Panel/VBox"]
text = "[ ] Collect 3 items"

[node name="Task2Label" type="Label" parent="Panel/VBox"]
text = "[ ] Activate terminal"

[node name="Task3Label" type="Label" parent="Panel/VBox"]
text = "[ ] Grab the exit key"

[node name="Divider" type="HSeparator" parent="Panel/VBox"]

[node name="ItemsLabel" type="Label" parent="Panel/VBox"]
text = "Items: 0 / 3"

[node name="KeyLabel" type="Label" parent="Panel/VBox"]
text = "Key: NO"

[node name="Divider2" type="HSeparator" parent="Panel/VBox"]

[node name="MoveLabel" type="Label" parent="Panel/VBox"]
text = "Movement: WALK"
theme_override_colors/font_color = Color(0.6, 1, 0.6, 1)

[node name="BossWarning" type="Label" parent="."]
anchor_left = 0.5
anchor_top = 0.15
anchor_right = 0.5
anchor_bottom = 0.15
offset_left = -200.0
offset_right = 200.0
text = "⚠ BOSS IS CHASING YOU! RUN! ⚠"
theme_override_colors/font_color = Color(1, 0.1, 0.1, 1)
theme_override_font_sizes/font_size = 24
horizontal_alignment = 1
visible = false
